<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="350.0" prefWidth="450.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.licensify.app.controller.RequestFormController" style="-fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-width: 1px;">
    <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
        <Label fx:id="lblTitle" text="Request License" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #f8fafc;" />
        
        <VBox spacing="8.0">
            <Label text="Duration" style="-fx-font-weight: 600; -fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
            <ComboBox fx:id="comboDuration" prefWidth="390.0" style="-fx-background-color: #1e293b; -fx-text-fill: #f8fafc; -fx-border-color: #334155; -fx-border-radius: 6px; -fx-background-radius: 6px;" />
        </VBox>
        
        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
            <Label fx:id="lblDetails" text="Product &amp; Features" style="-fx-font-weight: 600; -fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
            <TextArea fx:id="txtFeatures" prefRowCount="4" promptText="Specify product name and required features..." wrapText="true" style="-fx-control-inner-background: #1e293b; -fx-text-fill: #f8fafc; -fx-prompt-text-fill: #64748b; -fx-border-color: #334155; -fx-border-radius: 6px; -fx-background-radius: 6px;" />
        </VBox>
        
        <Region VBox.vgrow="ALWAYS" />

        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button mnemonicParsing="false" text="Cancel" onAction="#handleCancel" styleClass="btn-secondary" />
            <Button mnemonicParsing="false" fx:id="btnSubmit" text="Submit Request" onAction="#handleSubmit" styleClass="btn-primary" />
        </HBox>
    </VBox>
</AnchorPane>
