<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.licensify.app.controller.UserDashboardController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            
            <!-- TOP NAVBAR -->
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="navbar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="24.0" right="24.0" />
                    </padding>
                    <children>
                        <!-- Logo -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="240.0">
                            <FontIcon iconLiteral="fas-shield-alt" iconSize="24" iconColor="#3b82f6" />
                            <Label styleClass="title-label" text="Licensify" />
                        </HBox>
                        
                        <!-- Search Bar -->
                        <HBox alignment="CENTER_LEFT" styleClass="search-bar" HBox.hgrow="NEVER">
                            <FontIcon iconLiteral="fas-search" iconSize="14" iconColor="#64748b" style="-fx-translate-x: 5px;" />
                            <TextField promptText="Search licenses, requests..." style="-fx-background-color: transparent; -fx-border-color: transparent;" prefWidth="250.0" />
                        </HBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <!-- Right Icons & Profile -->
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <Button mnemonicParsing="false" styleClass="btn-icon">
                                <graphic>
                                    <FontIcon iconLiteral="far-bell" iconSize="18" iconColor="#94a3b8" />
                                </graphic>
                            </Button>
                            
                            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 0 0 0 10px; -fx-border-color: transparent transparent transparent rgba(255,255,255,0.1); -fx-border-width: 1px;">
                                <Circle radius="16.0" fill="#3b82f6" />
                                <VBox alignment="CENTER_LEFT">
                                    <Label fx:id="lblUserFullName" style="-fx-font-weight: 600; -fx-text-fill: #f8fafc; -fx-font-size: 13px;" text="User Name" />
                                    <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" text="Client Account" />
                                </VBox>
                                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="btn-icon">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#ef4444" />
                                    </graphic>
                                </Button>
                            </HBox>
                        </HBox>
                    </children>
                </HBox>
            </top>

            <!-- LEFT SIDEBAR -->
            <left>
                <VBox prefWidth="260.0" spacing="8.0" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 0 0 8px 12px;" text="MAIN MENU" />
                        
                        <Button fx:id="btnNavDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item, nav-active" text="Dashboard">
                            <graphic><FontIcon iconLiteral="fas-home" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                        <Button fx:id="btnNavLicenses" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item" text="My Licenses">
                            <graphic><FontIcon iconLiteral="fas-key" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                        <Button fx:id="btnNavRequests" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item" text="Renewal Requests">
                            <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                        <Button fx:id="btnNavDownloads" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item" text="Downloads">
                            <graphic><FontIcon iconLiteral="fas-download" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                        
                        <Region VBox.vgrow="ALWAYS" />
                        
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 0 0 8px 12px;" text="PREFERENCES" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item" text="Settings">
                            <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboardPanel" styleClass="nav-item" text="Help Center">
                            <graphic><FontIcon iconLiteral="fas-question-circle" iconSize="16" style="-fx-translate-x: -10px;" /></graphic>
                        </Button>
                    </children>
                </VBox>
            </left>

            <!-- MAIN DASHBOARD CONTENT -->
            <center>
                <StackPane fx:id="mainStackPane" BorderPane.alignment="CENTER">
                    <!-- DASHBOARD PANEL -->
                    <ScrollPane fx:id="panelDashboard" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                        <content>
                            <VBox spacing="24.0" style="-fx-padding: 30px 40px;">
                                <children>
                                    
                                    <!-- Header Title -->
                                    <HBox alignment="CENTER_LEFT">
                                        <VBox>
                                            <Label style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #f8fafc;" text="Dashboard Overview" />
                                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Track your licenses, usage analytics, and recent requests." />
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleRequestNewLicense" styleClass="btn-primary" text="Request License">
                                            <graphic><FontIcon iconLiteral="fas-plus" iconColor="white" /></graphic>
                                        </Button>
                                    </HBox>

                                    <!-- ROW 1: 4 Statistic Cards -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <!-- Card 1: Total Licenses -->
                                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                                <VBox alignment="CENTER" styleClass="stat-icon-wrapper, stat-icon-primary">
                                                    <FontIcon iconLiteral="fas-key" iconSize="24" />
                                                </VBox>
                                                <VBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: 600;" text="Total Licenses" />
                                                    <Label fx:id="lblStatTotal" style="-fx-text-fill: #f8fafc; -fx-font-size: 28px; -fx-font-weight: 700;" text="0" />
                                                </VBox>
                                            </HBox>

                                            <!-- Card 2: Active Licenses -->
                                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                                <VBox alignment="CENTER" styleClass="stat-icon-wrapper, stat-icon-success">
                                                    <FontIcon iconLiteral="fas-check-circle" iconSize="24" />
                                                </VBox>
                                                <VBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: 600;" text="Active Licenses" />
                                                    <Label fx:id="lblStatActive" style="-fx-text-fill: #f8fafc; -fx-font-size: 28px; -fx-font-weight: 700;" text="0" />
                                                </VBox>
                                            </HBox>

                                            <!-- Card 3: Expiring Soon -->
                                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                                <VBox alignment="CENTER" styleClass="stat-icon-wrapper, stat-icon-warning">
                                                    <FontIcon iconLiteral="fas-exclamation-triangle" iconSize="24" />
                                                </VBox>
                                                <VBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: 600;" text="Expiring Soon" />
                                                    <Label fx:id="lblStatExpiring" style="-fx-text-fill: #f8fafc; -fx-font-size: 28px; -fx-font-weight: 700;" text="0" />
                                                </VBox>
                                            </HBox>

                                            <!-- Card 4: Pending Requests -->
                                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                                <VBox alignment="CENTER" styleClass="stat-icon-wrapper, stat-icon-danger">
                                                    <FontIcon iconLiteral="fas-clock" iconSize="24" />
                                                </VBox>
                                                <VBox alignment="CENTER_LEFT">
                                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: 600;" text="Pending Requests" />
                                                    <Label fx:id="lblStatPending" style="-fx-text-fill: #f8fafc; -fx-font-size: 28px; -fx-font-weight: 700;" text="0" />
                                                </VBox>
                                            </HBox>
                                        </children>
                                    </HBox>

                                    <!-- ROW 2: Analytics Charts -->
                                    <HBox spacing="24.0" prefHeight="350.0">
                                        <children>
                                            <VBox spacing="15.0" styleClass="saas-card" HBox.hgrow="ALWAYS">
                                                <Label styleClass="header-text" text="License Usage by Type" />
                                                <BarChart fx:id="usageBarChart" animated="true" legendVisible="false" VBox.vgrow="ALWAYS">
                                                    <xAxis>
                                                        <CategoryAxis side="BOTTOM" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <NumberAxis side="LEFT" />
                                                    </yAxis>
                                                </BarChart>
                                            </VBox>
                                            <VBox spacing="15.0" styleClass="saas-card" prefWidth="400.0">
                                                <Label styleClass="header-text" text="License Health" />
                                                <PieChart fx:id="statusPieChart" animated="true" labelsVisible="false" legendSide="BOTTOM" VBox.vgrow="ALWAYS" />
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <!-- ROW 3 & 4: Tables and Timeline -->
                                    <HBox spacing="24.0">
                                        <children>
                                            <!-- ROW 3: Recent Licenses Table -->
                                            <VBox spacing="15.0" styleClass="saas-card" HBox.hgrow="ALWAYS">
                                                <HBox alignment="CENTER_LEFT">
                                                    <Label styleClass="header-text" text="Recent Licenses" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button mnemonicParsing="false" styleClass="btn-secondary" text="View All" onAction="#showDashboardPanel" />
                                                </HBox>
                                                <TableView fx:id="recentLicensesTable" prefHeight="250.0" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colLicKey" prefWidth="120.0" text="License Key" />
                                                        <TableColumn fx:id="colLicProduct" prefWidth="150.0" text="Product" />
                                                        <TableColumn fx:id="colLicType" prefWidth="100.0" text="Type" />
                                                        <TableColumn fx:id="colLicStatus" prefWidth="100.0" text="Status" />
                                                        <TableColumn fx:id="colLicExpiry" prefWidth="120.0" text="Expiry Date" />
                                                        <TableColumn fx:id="colLicAction" prefWidth="80.0" text="Actions" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </VBox>

                                            <!-- ROW 4: Recent Requests Timeline -->
                                            <VBox spacing="15.0" styleClass="saas-card" prefWidth="350.0">
                                                <Label styleClass="header-text" text="Recent Activity" />
                                                <VBox fx:id="timelineContainer" spacing="0.0" VBox.vgrow="ALWAYS" />
                                            </VBox>
                                        </children>
                                    </HBox>

                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- MY LICENSES PANEL -->
                    <VBox fx:id="panelMyLicenses" visible="false" spacing="24.0" style="-fx-padding: 30px 40px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #f8fafc;" text="My Licenses" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#handleRequestNewLicense" styleClass="btn-primary" text="Request New License">
                                <graphic><FontIcon iconLiteral="fas-plus" iconColor="white" /></graphic>
                            </Button>
                        </HBox>
                        <TableView fx:id="myLicensesFullTable" VBox.vgrow="ALWAYS" styleClass="saas-card">
                            <columns>
                                <TableColumn fx:id="colMyLicKey" prefWidth="150.0" text="License Key" />
                                <TableColumn fx:id="colMyLicProduct" prefWidth="200.0" text="Product" />
                                <TableColumn fx:id="colMyLicType" prefWidth="120.0" text="Type" />
                                <TableColumn fx:id="colMyLicStatus" prefWidth="120.0" text="Status" />
                                <TableColumn fx:id="colMyLicExpiry" prefWidth="150.0" text="Expiry Date" />
                                <TableColumn fx:id="colMyLicAction" prefWidth="120.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- RENEWAL REQUESTS PANEL -->
                    <VBox fx:id="panelRequests" visible="false" spacing="24.0" style="-fx-padding: 30px 40px;">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #f8fafc;" text="Renewal Requests" />
                        </HBox>
                        <TableView fx:id="requestsFullTable" VBox.vgrow="ALWAYS" styleClass="saas-card">
                            <columns>
                                <TableColumn fx:id="colReqId" prefWidth="80.0" text="Request ID" />
                                <TableColumn fx:id="colReqType" prefWidth="120.0" text="Type" />
                                <TableColumn fx:id="colReqStatus" prefWidth="120.0" text="Status" />
                                <TableColumn fx:id="colReqDate" prefWidth="150.0" text="Date Submitted" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </StackPane>
            </center>

        </BorderPane>
    </children>
</AnchorPane>
