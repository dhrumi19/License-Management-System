<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="580.0" prefWidth="500.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.licensify.app.controller.DownloadFormController">
   <children>
      <VBox spacing="22.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Title Bar -->
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" text="📥 Download Licence File" />
                  <Label styleClass="subtitle-label" text="Generate .dat and .json licence files for deployment" />
               </children>
            </VBox>
            
            <VBox prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.08);" />
            
            <!-- Selection Area -->
            <VBox spacing="8.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 14px;" text="Select Licence" />
                  <ComboBox fx:id="licenseComboBox" maxWidth="1.7976931348623157E308" promptText="Select a Licence to Export" styleClass="combo-box" />
               </children>
            </VBox>
            
            <!-- Format Selection -->
            <VBox spacing="15.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 14px;" text="File Formats" />
                  
                  <!-- DAT format -->
                  <VBox spacing="4.0">
                     <children>
                        <CheckBox fx:id="chkDat" mnemonicParsing="false" selected="true" styleClass="check-box" text="Licence Data File (.dat)" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 0 0 0 22px;" text="Structured key-value data file with checksum verification" />
                     </children>
                  </VBox>
                  
                  <!-- JSON format -->
                  <VBox spacing="4.0">
                     <children>
                        <CheckBox fx:id="chkJson" mnemonicParsing="false" selected="true" styleClass="check-box" text="Licence JSON File (.json)" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-padding: 0 0 0 22px;" text="Full licence data in JSON format with features and hardware binding" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <!-- Info Banner -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: rgba(59, 130, 246, 0.1); -fx-border-color: rgba(59, 130, 246, 0.3); -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px;">
               <children>
                  <Label style="-fx-text-fill: #60a5fa; -fx-font-weight: bold; -fx-font-size: 16px;" text="🛈" />
                  <Label style="-fx-text-fill: #60a5fa; -fx-font-size: 12px;" text="Both files will be saved to the same folder with the licence ID as filename." wrapText="true" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            
            <VBox prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.08);" VBox.vgrow="ALWAYS" />
            
            <!-- Buttons -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="38.0" prefWidth="100.0" styleClass="btn-secondary" text="Cancel" />
                  <Button fx:id="downloadBtn" mnemonicParsing="false" onAction="#handleDownload" prefHeight="38.0" prefWidth="160.0" styleClass="btn-success" text="💾 Download Files" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
