<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.licensify.app.controller.LoginController" stylesheets="@../css/styles.css">
   <children>
      <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox fx:id="loginContainer" alignment="CENTER" maxWidth="400.0" spacing="25.0" styleClass="glass-pane">
               <children>
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="title-label" text="Licensify">
                           <font>
                              <Font name="System Bold" size="28.0" />
                           </font>
                        </Label>
                        <Label styleClass="subtitle-label" text="Secure License Management System" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="subtitle-label" text="Username" />
                              <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-field" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="subtitle-label" text="Password" />
                              <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" styleClass="btn-primary" text="Login" />
                        <Label fx:id="errorLabel" alignment="CENTER" style="-fx-text-fill: #ef4444; -fx-font-size: 12px;" text="" visible="false" wrapText="true" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
